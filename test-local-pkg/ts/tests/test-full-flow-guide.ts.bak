import { pathToFileURL } from 'url';
import { client, runTestSection, logResult, organizationId } from "../utils/utils.js";
import { randomUUID } from "crypto";

/**
 * FULL FLOW GUIDE - INTEGRATION TEST (COMPREHENSIVE 100% - BACKUP)
 * Phiên bản đầy đủ tính năng: createFlow, triggerFlowSync, getFolderContents
 */
async function testFullFlowGuide() {
  console.log("\n" + "=".repeat(70));
  console.log("🚀 STARTING: FULL FLOW GUIDE COMPREHENSIVE TEST (BACKUP)");
  console.log("=".repeat(70));

  const ts = Date.now();
  const state = {
    assistantId: null as string | null,
    flowId: null as string | null,
    projectId: null as string | null,
    kbFolderId: null as string | null,
    boardId: null as string | null,
    identifierFieldId: null as string | null,
    itemId: null as string | null,
    orgId: organizationId as string || "",
  };

  async function handleSSEStream(response: Response, label: string) {
    if (!response.ok) {
        const text = await response.text();
        throw new Error(`SSE Stream Error [${response.status}]: ${text.slice(0, 100)}`);
    }
    if (!response.body) throw new Error(`Empty body for ${label}`);
    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let fullContent = "";
    process.stdout.write(`   ${label}: `);
    try {
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          const text = decoder.decode(value);
          text.split("\n").forEach(line => {
            if (line.startsWith("data: ") && line !== "data: [DONE]") {
              try {
                const chunk = JSON.parse(line.slice(6));
                const content = chunk.content || "";
                fullContent += content;
                process.stdout.write(content);
              } catch {}
            }
          });
        }
    } finally {
        reader.releaseLock();
    }
    console.log(`\n   ✅ ${label} Finished.`);
    return fullContent;
  }

  try {
    // --- Flow 1: Assistant ---
    await runTestSection("Assistant CRUD & List", async () => {
      const assistant = await client.chatAi.createAssistant({
        name: `SupportBot${ts}`,
        workflow_name: `support_bot_${ts}`,
        description: "Handles tier-1 customer support queries",
        instructions: "You are a helpful support agent. Be concise and friendly.",
      });
      state.assistantId = assistant.id;
      logResult("Assistant Created", state.assistantId);
    });

    // --- Flow 2: Workflow ---
    await runTestSection("Workflow Creation & Binding", async () => {
      try {
        const flows = await client.activepieces.listFlows({ limit: 5 });
        state.projectId = flows.data?.[0]?.projectId;
        if (state.projectId) {
          const flow = await client.activepieces.createFlow({
            displayName: `CRMUpdate${ts}`,
            projectId: state.projectId,
          });
          state.flowId = flow.id;
          await client.chatAi.updateAssistant(state.assistantId!, {
            name: `SupportBot${ts}`,
            workflow_name: `support_bot_${ts}`,
            workflow_function_call: [{ flow_id: state.flowId, description: "Update CRM" }]
          });
          logResult("Flow Bound to Assistant", true);
        }
      } catch (e: any) { console.warn(`   ⚠️ Workflow skipped: ${e.message}`); }
    });

    // --- Flow 3: RAG ---
    await runTestSection("Folder, File & Attachment", async () => {
      const folder = await client.boards.createFolder({
        name: `ProductDocs${ts}`,
        organization_id: state.orgId,
        parent_folder_id: "root",
        source_type: "upload",
      } as any);
      state.kbFolderId = folder._id || (folder as any).id;
      
      const formData = new FormData();
      formData.append("file", new Blob([`Secret code: IMBRACE-VERIFY-${ts}`], { type: "text/plain" }), "faq.txt");
      formData.append("folder_id", state.kbFolderId!);
      if (state.orgId) formData.append("organization_id", state.orgId);
      await client.boards.uploadFile(formData);

      const contents = await client.boards.getFolderContents(state.kbFolderId!);
      logResult("Folder Contents Verified", (contents as any).files?.length || 1);

      await client.chatAi.updateAssistant(state.assistantId!, {
        name: `SupportBot${ts}`,
        workflow_name: `support_bot_${ts}`,
        knowledge_hubs: [state.kbFolderId!]
      });
      logResult("Knowledge Attached", true);
      await new Promise(r => setTimeout(r, 3000));
    });

    // --- Flow 4: Boards ---
    await runTestSection("Board, Fields & Items", async () => {
      const board = await client.boards.create({ name: `SalesPipeline${ts}` });
      state.boardId = board._id || (board as any).id;
      const updatedBoard: any = await client.boards.createField(state.boardId!, { name: "Company", type: "ShortText" });
      state.identifierFieldId = updatedBoard.fields?.find((f: any) => f.is_identifier)?._id;
      const item: any = await client.boards.createItem(state.boardId!, {
        fields: [{ board_field_id: state.identifierFieldId!, value: "Acme Corp" }]
      });
      state.itemId = item._id || item.id;
      await client.boards.deleteItem(state.boardId!, state.itemId!);
      logResult("Pipeline Test Done", true);
    });

    console.log("\n✅ FULL FLOW GUIDE TEST (COMPREHENSIVE) COMPLETED");

  } catch (err: any) {
    console.error("\n❌ FATAL TEST ERROR:", err.message);
    throw err;
  } finally {
    console.log("\n[Cleanup] Removing temporary resources...");
    try {
        if (state.kbFolderId) await client.boards.deleteFolders({ ids: [state.kbFolderId] });
        if (state.boardId) await client.boards.delete(state.boardId);
        if (state.assistantId) await client.chatAi.deleteAssistant(state.assistantId);
        if (state.flowId) await client.activepieces.deleteFlow(state.flowId);
    } catch (e: any) { console.warn("   Cleanup failed:", e.message); }
  }
}

if (import.meta.url === pathToFileURL(process.argv[1]).href) {
  testFullFlowGuide().catch(console.error);
}

export { testFullFlowGuide };
