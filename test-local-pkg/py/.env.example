# test-local-pkg/py — local SDK verification (editable install of ../../py)
# Copy to .env and fill in real values.
# Provide EITHER IMBRACE_API_KEY OR IMBRACE_ACCESS_TOKEN — the test client
# auto-picks Access Token if both are set.
IMBRACE_API_KEY=api_xxxxxxxxxxxxxxxx
# IMBRACE_ACCESS_TOKEN=acc_xxxxxxxxxxxxxxxx
IMBRACE_ORGANIZATION_ID=org_xxxxxxxxxxxxxxxx
# Optional override (defaults to https://app-gatewayv2.imbrace.co)
# IMBRACE_GATEWAY_URL=
# Optional for fix #3 (aiAgent.suggest_field_types) — needs a public PDF/image URL.
# IMBRACE_SAMPLE_DOC_URL=https://app-gatewayv2.imbrace.co/files/download/sample.pdf
