{
  "name": "@imbrace/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript/JavaScript SDK for Imbrace — dual auth (API Key + Access Token)",
  "type": "module",
  "license": "MIT",
  "author": "Imbrace Team <dev@imbrace.co>",
  "homepage": "https://imbrace.co",
  "repository": {
    "type": "git",
    "url": "https://github.com/imbrace/sdk.git",
    "directory": "ts"
  },
  "keywords": [
    "imbrace",
    "sdk",
    "api",
    "typescript",
    "javascript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./app/client": {
      "import": "./dist/app/client.js",
      "types": "./dist/app/client.d.ts"
    },
    "./server/client": {
      "import": "./dist/server/client.js",
      "types": "./dist/server/client.d.ts"
    },
    "./journey/client": {
      "import": "./dist/journey/client.js",
      "types": "./dist/journey/client.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "test:watch": "vitest tests/unit",
    "test:bun": "bun x vitest run tests/unit",
    "test:bun:watch": "bun x vitest tests/unit",
    "gen": "bun script/build.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.95.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^20.0.0",
    "@vitest/ui": "^1.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
