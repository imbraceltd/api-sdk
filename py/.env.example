# ================================================
# Imbrace SDK — Configuration
# ================================================
# Copy file này thành .env và điền thông tin của bạn:
#   cp .env.example .env

# ─── REQUIRED ──────────────────────────────────
# API Key lấy từ response của Imbrace auth endpoint
# Đây là giá trị của trường: response.apiKey.apiKey
IMBRACE_API_KEY=your-api-key-here
IMBRACE_ORG_ID=org_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ─── OPTIONAL ──────────────────────────────────
# Base URL của Imbrace Gateway 
IMBRACE_BASE_URL=https://app-gatewayv2.imbrace.co

# ─── DEV/TEST ──────────────────────────────────
# Dùng khi muốn test với server local
# IMBRACE_BASE_URL=http://localhost:4096
