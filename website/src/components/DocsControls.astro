---
// Top-of-sidebar preference panel modelled on the Next.js docs sidebar.
// Two grouped fields — Auth mode and SDK version — each with a label, a
// select, and a one-line description that updates with the selection.
//
// Selection persists in localStorage and is mirrored onto
// <html data-auth="..." data-version="..."> so CSS in custom.css can show or
// hide content blocks marked with <AuthOnly mode="..."> and
// <VersionOnly version="...">.

const authOptions = [
  {
    value: 'access-token',
    label: 'Access Token',
    desc: 'Imbrace IS your backend — end-users log in via OTP.',
  },
  {
    value: 'api-key',
    label: 'API Key',
    desc: 'Wrap Imbrace inside your own backend — server-to-server.',
  },
] as const

const versionOptions = [
  {
    value: '1.0.4',
    label: 'v1.0.4 (latest)',
    desc: 'Released May 2026 — current stable.',
  },
] as const

const defaultAuth = 'access-token'
const defaultVersion = '1.0.4'

const authJson = JSON.stringify(
  Object.fromEntries(authOptions.map((o) => [o.value, o.desc]))
)
const versionJson = JSON.stringify(
  Object.fromEntries(versionOptions.map((o) => [o.value, o.desc]))
)
---

<aside class="docs-controls" aria-label="Documentation preferences">
  <div class="docs-controls__field">
    <div class="docs-controls__label">Auth</div>
    <select class="docs-auth-select" data-default={defaultAuth}>
      {authOptions.map((opt) => (
        <option value={opt.value} selected={opt.value === defaultAuth}>{opt.label}</option>
      ))}
    </select>
    <p class="docs-controls__desc" data-desc-target="auth">
      {authOptions.find((o) => o.value === defaultAuth)?.desc}
    </p>
  </div>

  <div class="docs-controls__field">
    <div class="docs-controls__label">Version</div>
    <select class="docs-version-select" data-default={defaultVersion}>
      {versionOptions.map((opt) => (
        <option value={opt.value} selected={opt.value === defaultVersion}>{opt.label}</option>
      ))}
    </select>
    <p class="docs-controls__desc" data-desc-target="version">
      {versionOptions.find((o) => o.value === defaultVersion)?.desc}
    </p>
  </div>
</aside>

<script is:inline define:vars={{ defaultAuth, defaultVersion, authJson, versionJson }}>
  ;(function () {
    if (window.__imbraceDocsControlsInit) return
    window.__imbraceDocsControlsInit = true

    const root = document.documentElement
    const AUTH_KEY = 'imbrace-docs-auth'
    const VER_KEY = 'imbrace-docs-version'

    const authDescs = JSON.parse(authJson)
    const versionDescs = JSON.parse(versionJson)

    const auth = localStorage.getItem(AUTH_KEY) || defaultAuth
    const ver = localStorage.getItem(VER_KEY) || defaultVersion
    root.setAttribute('data-auth', auth)
    root.setAttribute('data-version', ver)

    function syncDesc(target, value) {
      document.querySelectorAll('[data-desc-target="' + target + '"]').forEach((node) => {
        const map = target === 'auth' ? authDescs : versionDescs
        if (map[value]) node.textContent = map[value]
      })
    }

    function wire(selector, key, attr, target) {
      const els = document.querySelectorAll(selector)
      const stored = localStorage.getItem(key)
      els.forEach((el) => {
        if (stored) el.value = stored
        el.addEventListener('change', () => {
          localStorage.setItem(key, el.value)
          root.setAttribute(attr, el.value)
          els.forEach((other) => { if (other !== el) other.value = el.value })
          syncDesc(target, el.value)
        })
      })
      // Initial description sync on load (handles persisted selection)
      syncDesc(target, stored || (target === 'auth' ? defaultAuth : defaultVersion))
    }

    function init() {
      wire('.docs-auth-select', AUTH_KEY, 'data-auth', 'auth')
      wire('.docs-version-select', VER_KEY, 'data-version', 'version')
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init)
    } else {
      init()
    }
  })()
</script>

<style>
  .docs-controls {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 0.9rem 1rem 1rem;
    margin: 0 0 1rem;
    background: var(--sl-color-bg-sidebar);
    border-bottom: 1px solid var(--sl-color-hairline-shade);
  }
  .docs-controls__field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .docs-controls__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }
  .docs-controls select {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-text);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.45rem;
    padding: 0.55rem 2rem 0.55rem 0.7rem;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    background-image: linear-gradient(45deg, transparent 50%, currentColor 50%),
      linear-gradient(135deg, currentColor 50%, transparent 50%);
    background-position: calc(100% - 1.1rem) 50%, calc(100% - 0.75rem) 50%;
    background-size: 0.32rem 0.32rem, 0.32rem 0.32rem;
    background-repeat: no-repeat;
    transition: border-color 120ms ease;
  }
  .docs-controls select:hover {
    border-color: var(--sl-color-text-accent);
  }
  .docs-controls select:focus-visible {
    outline: 2px solid var(--sl-color-text-accent);
    outline-offset: 2px;
  }
  .docs-controls__desc {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--sl-color-gray-3);
  }
</style>
